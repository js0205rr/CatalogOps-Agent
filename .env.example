# CatalogOps-Agent runs fully in mock/rule-first mode without external services.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-turbo
ANSWER_LLM_TEMPERATURE=0

# Keep true for deterministic local demos and pytest.
CATALOGOPS_MOCK_LLM=true
USE_MOCK=true

# API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
MAX_UPLOAD_BYTES=10485760
MAX_CSV_ROWS=200000

# Optional future RAG backends. Empty values keep local policy-doc mock mode.
MILVUS_URI=
MILVUS_COLLECTION=catalogops_policy_chunks
POLICY_EMBEDDING_PROVIDER=minilm
POLICY_EMBEDDING_MODEL_PATH=models/all-MiniLM-L6-v2
OPENAI_EMBEDDING_MODEL=text-embedding-v3
POLICY_CANDIDATE_TOP_N=12
POLICY_RERANKER_MODE=lexical
POLICY_RRF_K=60
POSTGRES_DSN=
